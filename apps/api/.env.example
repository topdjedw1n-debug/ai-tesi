# Database
DATABASE_URL=postgresql://thesica_user:thesica_password@localhost/thesica_db

# Security
SECRET_KEY=your-secret-key-min-32-chars-long-change-this
JWT_SECRET=another-secret-key-min-32-chars-change-this

# AI APIs
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
TAVILY_API_KEY=tvly-your-tavily-api-key-here
OPENALEX_API_KEY=your-openalex-api-key-here

# Semantic Scholar API - academic paper search + citation verification.
# We run with an AUTHENTICATED key (unkeyed access is throttled to HTTP 429).
# Get one at: https://www.semanticscholar.org/product/api#api-key
# Consumed by app/services/citation_verifier.py and ai_pipeline/rag_retriever.py.
SEMANTIC_SCHOLAR_API_KEY=s2k-your-semantic-scholar-api-key-here

# AI Retry & Fallback Configuration (Task 3.1-3.2)
# Number of retry attempts per AI provider (default: 3)
AI_MAX_RETRIES=3
# Comma-separated retry delays in seconds - exponential backoff (default: 2,4,8)
AI_RETRY_DELAYS=2,4,8
# Enable automatic fallback to other providers on failure (default: true)
AI_ENABLE_FALLBACK=true
# Fallback chain: comma-separated "provider:model" pairs, tried in order
# Default: GPT-4 → GPT-3.5 Turbo → Claude 3.5 Sonnet
# Format: "provider:model,provider:model,..."
# Examples:
#   - "openai:gpt-4,anthropic:claude-3-5-sonnet-20241022"
#   - "anthropic:claude-3-5-sonnet-20241022,openai:gpt-4"
AI_FALLBACK_CHAIN=openai:gpt-4,openai:gpt-3.5-turbo,anthropic:claude-3-5-sonnet-20241022

# Quality Gates Configuration (Task 3.2 - Auto-rejection of poor quality)
# Grammar threshold: max errors before regeneration (default: 10)
QUALITY_MAX_GRAMMAR_ERRORS=10
# Plagiarism threshold: min uniqueness % required (default: 85 = 15% plagiarism allowed)
QUALITY_MIN_PLAGIARISM_UNIQUENESS=85.0
# AI detection threshold: max AI-generated % before multi-pass humanization (default: 55)
QUALITY_MAX_AI_DETECTION_SCORE=35.0
# Max regeneration attempts per section if quality fails (default: 2, total 3 attempts)
QUALITY_MAX_REGENERATE_ATTEMPTS=2
# Enable quality gates: set false to disable rejection logic (default: true)
QUALITY_GATES_ENABLED=true
# Context limit: max previous sections in context to prevent token explosion (default: 10)
QUALITY_GATES_MAX_CONTEXT_SECTIONS=10

# Academic Quality Engine (Phase 1 evidence)
# Provenance should stay on for internal proof runs; it powers the manager
# QA Evidence card and the admin provenance timeline.
PROVENANCE_LEDGER_ENABLED=true
# Citation verification is the foundation for claim support. Use mark_only
# for early runs when provider access is still being checked; strict can mark
# documents failed_quality when sources are not found.
CITATION_VERIFICATION_ENABLED=false
CITATION_VERIFICATION_POLICY=mark_only
# Claim verification depends on citation verification because it reads source
# abstracts from verified DocumentSource rows.
CLAIM_VERIFICATION_ENABLED=false
CLAIM_VERIFICATION_MAX_CHECKS=50
# Blocking claim mode (needs CLAIM_VERIFICATION_ENABLED): unsupported cited
# claims block export instead of only being recorded.
CLAIM_VERIFICATION_BLOCKING=false
# Source grounding: build one topic-locked source pack per document upfront
# (Crossref/OpenAlex) and write sections closed-book against its keys.
# Requires migration 011. Grounding gate re-generates sections whose citations
# don't resolve to on-topic pack sources; mark_only never hard-fails.
SOURCE_GROUNDING_ENABLED=false
SOURCE_PACK_TARGET_SIZE=24
SOURCE_PACK_MIN_ON_TOPIC_SCORE=0.35
GROUNDING_GATE_ENABLED=false
GROUNDING_GATE_POLICY=mark_only
GROUNDING_MIN_RATE=0.8
# Also require a concrete numeric detail per section (citation years and
# section numbering don't count); missing evidence triggers regeneration.
GROUNDING_REQUIRE_EVIDENCE=true
# Reviewer panel adds multiple LLM calls per section; enable after the 20-page
# sanity run if token budget allows.
QUALITY_PANEL_ENABLED=false
QUALITY_PANEL_PASS_SCORE=70.0
QUALITY_PANEL_MIN_REVIEWERS=2

# MVP Free Generation (Stage 0: "fix MVP scope & disable sales")
# When true, POST /generate/full-document runs without a completed Stripe
# payment, bounded by the guardrails below. When false (code default), a
# completed payment is required (402 otherwise). Set true for the MVP build.
MVP_FREE_GENERATION_ENABLED=true
# Max pages allowed per free generation (400 if a document exceeds it)
MVP_FREE_GENERATION_MAX_PAGES=20
# Max free generations per user per day (429 when reached)
MVP_FREE_GENERATION_DAILY_USER_LIMIT=2
# Hard daily token budget enforced before a job is created (429 if the
# projected job would exceed today's remaining budget). Empty = disabled.
DAILY_TOKEN_LIMIT=2000000

# AI Detection APIs
GPTZERO_API_KEY=your-gptzero-api-key-here
ORIGINALITY_AI_API_KEY=your-originality-api-key-here
AI_DETECTION_ENABLED=true

# Quality Check APIs
LANGUAGETOOL_API_URL=https://api.languagetool.org/v2
LANGUAGETOOL_API_KEY=your-languagetool-api-key-optional
LANGUAGETOOL_ENABLED=true

COPYSCAPE_API_KEY=your-copyscape-api-key-here
COPYSCAPE_USERNAME=your-copyscape-username-here

# Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=thesica-documents

# Redis
REDIS_URL=redis://localhost:6379

# Payment
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS & Security
# Comma-separated list of allowed frontend origins (required in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Comma-separated list of allowed hosts (required in production)
ALLOWED_HOSTS=["localhost","127.0.0.1"]
# Frontend URL for generating magic links and redirects
FRONTEND_URL=http://localhost:3000
