# ============================================================================
# Thesica Frontend Environment Variables (Next.js) — example
# ============================================================================
# Copy to .env.local and fill in real values. Do NOT commit .env.local.
# ============================================================================

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Stripe Configuration (Frontend)
# ----------------------------------------------------------------------------
# Stripe Publishable Key — safe to expose in the frontend.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=false

# Sales flow (Stage 0 / "fix MVP scope & disable sales").
# false = MVP free mode: document creation skips pricing/payment and
#         generation is started manually from the document page.
# true  = client-facing sales: payment is required before generation.
# The refund flow additionally requires the payment flow to be on.
NEXT_PUBLIC_ENABLE_USER_PAYMENT_FLOW=false
NEXT_PUBLIC_ENABLE_USER_REFUND_FLOW=false

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Thesica
NEXT_PUBLIC_APP_URL=https://thesica.ai
